# Use a deny-by-default build context. The Dockerfile copies only these inputs.
**

# Python server runtime sources and locked dependency metadata.
!python/
!python/pyproject.toml
!python/uv.lock
!python/README.md
!python/valuecell/
!python/valuecell/**
!python/configs/
!python/configs/**
!python/apscheduler/
!python/apscheduler/**

# Frontend build inputs.
!frontend/
!frontend/package.json
!frontend/bun.lock
!frontend/*.json
!frontend/*.ts
!frontend/*.tsx
!frontend/*.js
!frontend/*.cjs
!frontend/*.mjs
!frontend/src/
!frontend/src/**
!frontend/public/
!frontend/public/**
!frontend/scripts/
!frontend/scripts/**

# Docker build instructions.
!docker/
!docker/DockerFile
!docker/frontend.Dockerfile
!docker/frontend-nginx.conf
!docker-compose.local.yml
!.dockerignore

# Never send credentials, runtime environment files, local databases, or logs.
.env
.env.*
!.env.example
**/.env
**/.env.*
**/*.pem
**/*.key
**/*secret*
**/*credential*
**/*.db
**/*.sqlite
**/*.sqlite3
logs/
python/logs/

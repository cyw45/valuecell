FROM valuecell-backend-base:pre-rebuild

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/app/python/.venv/bin:$PATH" \
    PYTHONPATH=/app/python

WORKDIR /app/python

# Reuse the previously built dependency environment and replace only runtime
# source/config. This keeps local deploys working when external registries are
# unreachable during a rebuild.
RUN rm -rf /app/python/valuecell /app/python/configs /app/python/apscheduler
COPY python/valuecell ./valuecell
COPY python/configs ./configs
COPY python/apscheduler ./apscheduler

EXPOSE 8000

CMD ["python", "-m", "valuecell.server.main"]

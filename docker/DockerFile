FROM valuecell-backend-base:pre-rebuild

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/app/python/.venv/bin:$PATH" \
    PYTHONPATH=/app/python

WORKDIR /app/python

# The lockfile is copied before source so dependency changes invalidate this layer.
COPY python/pyproject.toml python/uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project

# Replace only runtime source/config after the locked dependency layer.
RUN rm -rf /app/python/valuecell /app/python/configs /app/python/apscheduler
COPY python/valuecell ./valuecell
COPY python/configs ./configs
COPY python/apscheduler ./apscheduler

EXPOSE 8000

CMD ["python", "-m", "valuecell.server.main"]

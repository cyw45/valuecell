# Copy the values below into docker/runtime/.env. Do not create a second
# checked-in .env file and do not send secret values through chat.

# WorldMonitor deployment source directory, normally a sibling checkout.
WORLDMONITOR_DIR=../worldmonitor
WORLDMONITOR_PUBLIC_URL=https://intel.example.com
WORLDMONITOR_PORT=13000

# Required WorldMonitor-internal secrets. Generate each independently:
# openssl rand -hex 32
RELAY_SHARED_SECRET=
REDIS_PASSWORD=
REDIS_TOKEN=

# Enabled intelligence data providers.
FRED_API_KEY=
EIA_API_KEY=
NASA_FIRMS_API_KEY=
ACLED_EMAIL=
ACLED_PASSWORD=
AISSTREAM_API_KEY=
FINNHUB_API_KEY=

# Refresh cadence. WorldMonitor cache seeders run every 15 minutes and
# ValueCell imports the normalized outputs every 5 minutes.
WM_SEED_INTERVAL_S=900
WORLD_MONITOR_SYNC_INTERVAL_S=300

# PostgreSQL for ValueCell. Generate a strong password; it must be URL-safe
# because Compose builds a SQLAlchemy connection URL from it.
VALUECELL_POSTGRES_DB=valuecell
VALUECELL_POSTGRES_USER=valuecell
VALUECELL_POSTGRES_PASSWORD=

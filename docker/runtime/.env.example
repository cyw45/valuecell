# ValueCell SaaS production runtime configuration.
# Copy to docker/runtime/.env or inject values with your deployment secret manager.
# Do not commit the resulting .env file or pass it to docker build.

# This is a VPS Docker template. Do not overwrite it with the Windows local
# %APPDATA%\\ValueCell\\.env file. The database host is intentionally different.

APP_NAME=ValueCell
APP_VERSION=0.1.0
APP_ENVIRONMENT=production

API_ENABLED=true
API_I18N_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

LANG=zh_CN
TIMEZONE=UTC
PYTHONIOENCODING=utf-8
AGENT_DEBUG_MODE=false

# Set explicit browser origins in production; do not use a wildcard.
CORS_ORIGINS=https://valuecell.example.com

# PostgreSQL runtime database. Keep the password only in this runtime file or
# your deployment secret manager; never add it to Git or a Docker image.
# VALUECELL_DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DATABASE
# VPS Docker -> VPS host PostgreSQL example:
# VALUECELL_DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@host.docker.internal:5432/DATABASE

# Tenant auth and credential encryption are required at runtime. Generate
# independent high-entropy values and store them in a secret manager when possible.
# VALUECELL_JWT_SECRET=replace_with_runtime_secret
# VALUECELL_CREDENTIAL_MASTER_KEY=base64url_encoded_32_byte_runtime_secret

# Backend-owned market snapshot. It preloads on startup, refreshes once a minute,
# retries each provider, and serves last successful real candles during outages.
VALUECELL_MARKET_DATA_PROVIDERS=gate,okx,binance,mexc
VALUECELL_MARKET_DEFAULT_SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT
VALUECELL_MARKET_DEFAULT_INTERVAL=1h
VALUECELL_MARKET_DEFAULT_LOOKBACK=240
VALUECELL_MARKET_REFRESH_S=60
VALUECELL_MARKET_DATA_MAX_CONCURRENT_FETCHES=12
VALUECELL_MARKET_DATA_PROVIDER_ATTEMPTS=2
VALUECELL_MARKET_DATA_CACHE_TTL_S=30

# AI strategy-advisory uses the existing backend model-provider configuration.
# HiCode is OpenAI-compatible: keep this token only in this runtime file or an
# external secret manager. It is never sent to the browser or stored per tenant.
# PRIMARY_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_BASE_URL=https://www.hi-code.cc/v1
# OPENAI_COMPATIBLE_API_KEY=replace_with_hicode_proxy_token
# The model id comes from python/configs/providers/openai-compatible.yaml.
# Change that configured default only when your HiCode account supports it.

# Live CEX execution is hard-disabled by default. Do not enable until the
# testnet workflow, API-key withdrawal restriction, IP allowlist, risk policy,
# strategy binding, and startup authorization have all been verified.
VALUECELL_LIVE_TRADING_ENABLED=false
VALUECELL_LIVE_AUTHORIZATION_TTL_S=900
OKX_ALLOW_LIVE_TRADING=false

# Host-side ports, when a compose deployment maps them.
VALUECELL_BACKEND_PORT=18000
VALUECELL_FRONTEND_PORT=18080

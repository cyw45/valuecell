# ValueCell production runtime env for Ubuntu VPS Docker deployment.
# Copy this file to docker/runtime/.env before first start.

APP_NAME=ValueCell
APP_VERSION=0.1.0
APP_ENVIRONMENT=production

API_ENABLED=true
API_I18N_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

LANG=zh_CN
TIMEZONE=Asia/Shanghai
PYTHONIOENCODING=utf-8

AGENT_DEBUG_MODE=false

# Reverse proxy / browser access
# Example: https://valuecell.example.com
CORS_ORIGINS=https://valuecell.example.com

# Main relational database used by SQLAlchemy models.
# PostgreSQL driver is psycopg.
VALUECELL_DATABASE_URL=postgresql+psycopg://scholarx:replace_with_real_password@142.171.201.216:5432/scholarx

# If you use your OpenAI-compatible relay, set these two and optionally PRIMARY_PROVIDER.
PRIMARY_PROVIDER=openai-compatible
OPENAI_COMPATIBLE_BASE_URL=https://www.hi-code.cc/v1
OPENAI_COMPATIBLE_API_KEY=

# Optional providers
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
GOOGLE_API_KEY=
SILICONFLOW_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=

# Optional data-source related values
SEC_EMAIL=your.name@example.com

# Host-side loopback ports used by docker-compose.vps.yml
VALUECELL_BACKEND_PORT=18000
VALUECELL_FRONTEND_PORT=18080

# ValueCell SaaS production runtime configuration.
# Copy to docker/runtime/.env or inject values with your deployment secret manager.
# Do not commit the resulting .env file or pass it to docker build.

APP_NAME=ValueCell
APP_VERSION=0.1.0
APP_ENVIRONMENT=production

API_ENABLED=true
API_I18N_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

LANG=en
TIMEZONE=UTC
PYTHONIOENCODING=utf-8
AGENT_DEBUG_MODE=false

# Set explicit browser origins in production; do not use a wildcard.
CORS_ORIGINS=https://valuecell.example.com

# Store this value in a runtime secret manager. Managed PostgreSQL deployments
# require a compatible SQLAlchemy PostgreSQL driver to be included in the image.
# VALUECELL_DATABASE_URL=postgresql+DRIVER://USER:PASSWORD@HOST:5432/DATABASE

# Tenant auth and credential-encryption secrets are required at runtime.
# Inject their exact values through the deployment secret manager; never commit them.
# VALUECELL_JWT_SECRET=replace_with_runtime_secret
# VALUECELL_CREDENTIAL_MASTER_KEY=replace_with_runtime_secret

# The SaaS API is paper-only. Keep live trading disabled.
OKX_ALLOW_LIVE_TRADING=false

# Host-side ports, when a compose deployment maps them.
VALUECELL_BACKEND_PORT=18000
VALUECELL_FRONTEND_PORT=18080
